{
    "Kestrel": {
        "Endpoints": {
            "Http": {
                "Url": "http://0.0.0.0:5000"
            }
        },
        "Limits": {
            "MaxConcurrentConnections": 200,
            "MaxConcurrentUpgradedConnections": 200,
            "KeepAliveTimeout": "00:02:00"
        }
    },
    "ApiKey": "",
    "RequestTimeoutSeconds": 300,
    "MaxRetryAttempts": 3,
    "DebugPrompt": false,
    "HealthCheck": {
        "Enabled": true,
        "IntervalSeconds": 30,
        "TimeoutSeconds": 5,
        "UnhealthyCooldownSeconds": 30
    },
    "Logging": {
        "LogLevel": {
            "Default": "Debug",
            "System.Net.Http.HttpClient": "Warning"
        }
    }
}