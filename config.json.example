{
  "local": [
    {
      "baseUrl": "http://192.168.1.100:8000/v1",
      "apiKey": "your-local-api-key",
      "models": [
        {
          "modelid": "gemma4-it-31b",
          "fallback": [
            "deepseek/deepseek-v4-flash",
            "deepseek/deepseek-v4-pro-thinking"
          ],
          "defaultParams": {
            "temperature": 0.0,
            "top_p": 0.9,
            "top_k": 40
          }
        },
        {
          "modelid": "gemma4-it-31b",
          "alias": "gemma4-it-31b-thinking",
          "defaultParams": {
            "temperature": 0.0,
            "top_p": 0.9,
            "top_k": 40,
            "enable_thinking": true
          }
        }
      ]
    }
  ],
  "deepseek": [
    {
      "baseUrl": "https://api.deepseek.com",
      "apiKey": "sk-your-deepseek-key",
      "models": [
        {
          "modelid": "deepseek-v4-pro",
          "defaultParams": {
            "temperature": 0.0,
            "top_p": 0.9,
            "top_k": 40,
            "thinking": {
              "type": "disabled"
            }
          }
        },
        {
          "modelid": "deepseek-v4-flash",
          "defaultParams": {
            "temperature": 0.0,
            "top_p": 0.9,
            "top_k": 40,
            "thinking": {
              "type": "disabled"
            }
          }
        },
        {
          "modelid": "deepseek-v4-pro-thinking",
          "defaultParams": {
            "temperature": 0.0,
            "top_p": 0.9,
            "top_k": 40
          }
        },
        {
          "modelid": "deepseek-v4-flash-thinking",
          "defaultParams": {
            "temperature": 0.0,
            "top_p": 0.9,
            "top_k": 40
          }
        }
      ]
    }
  ]
}
